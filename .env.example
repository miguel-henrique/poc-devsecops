# Copy to .env and adjust. Load before Terraform / Make: `set -a && source .env && set +a`
# Terraform maps these to variables when exported as TF_VAR_* (see Makefile).

TF_VAR_postgres_user=appuser
TF_VAR_postgres_password=change-me-use-strong-secret
TF_VAR_postgres_db=appdb
TF_VAR_backend_replica_count=2
TF_VAR_host_frontend_port=3000
TF_VAR_project_name=poc-devsecops
# TF_VAR_network_name=app-vpc

# Se o build do backend falhar com erro SSL ao baixar pacotes do PyPI (proxy corporativo):
# TF_VAR_pip_trusted_host_build=true

# docker-compose fallback (same values, without TF_VAR_ prefix)
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change-me-use-strong-secret
POSTGRES_DB=appdb
HOST_FRONTEND_PORT=3000

# Optional: non-default Docker socket (rootless, remote host, CI).
# TF_VAR_docker_host=unix:///var/run/docker.sock
